generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String     @id @default(uuid()) @db.Uuid
  username             String     @unique
  authVerifier         Bytes
  authSalt             Bytes
  publicKey            Bytes
  encPrivPw            Bytes
  pwKdfSalt            Bytes
  pwNonce              Bytes
  encPrivRec           Bytes
  recKdfSalt           Bytes
  recNonce             Bytes
  keyVersion           Int        @default(1)
  tokenVersion         Int        @default(0)
  emailEncrypted       Bytes?
  emailNonce           Bytes?
  emailKeyVersion      Int?
  emailVerified        Boolean    @default(false)
  notificationsEnabled Boolean    @default(true)
  role                 String     @default("user")
  mfaEmail             Boolean    @default(false)
  mfaTotp              Boolean    @default(false)
  mfaPasskey           Boolean    @default(false)
  totpSecret           Bytes?
  totpCreatedAt        DateTime?
  mfaRecoveryCodes     Bytes?
  mfaRecoveryCodesCreatedAt DateTime?
  recoveryCodeCreatedAt DateTime?
  createdAt            DateTime   @default(now())

  poBoxes            PoBox[]
  passkeyCredentials PasskeyCredential[]

  @@map("users")
}

model PoBox {
  id          String    @id @default(uuid()) @db.Uuid
  ownerId     String    @map("owner_id") @db.Uuid
  slug        String    @unique
  label       String
  greeting    String?
  isActive    Boolean   @default(true) @map("is_active")
  expiresAt   DateTime? @map("expires_at")
  maxMessages Int?      @map("max_messages")
  notify       Boolean   @default(true)
  passwordHash String?   @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")

  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("po_boxes")
}

model Message {
  id        String    @id @default(uuid()) @db.Uuid
  poBoxId   String    @map("po_box_id") @db.Uuid
  ciphertext Bytes
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  poBox PoBox @relation(fields: [poBoxId], references: [id], onDelete: Cascade)

  @@index([poBoxId, createdAt])
  @@map("messages")
}

model PasskeyCredential {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  credentialId Bytes     @unique @map("credential_id")
  publicKey    Bytes     @map("public_key")
  counter      Int       @default(0)
  transports   String?
  deviceName   String?   @map("device_name")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastUsedAt   DateTime? @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("passkey_credentials")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  actorId       String   @map("actor_id") @db.Uuid
  actorUsername String   @map("actor_username")
  action        String
  targetType    String   @map("target_type")
  targetId      String   @map("target_id")
  targetLabel   String?  @map("target_label")
  metadata      Json?
  ip            String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([action])
  @@index([actorId])
  @@map("audit_logs")
}
