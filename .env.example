# =============================================================================
# Virtual PO Box — Environment Configuration
# =============================================================================
# Copy this file to .env.local for development and fill in real values.
#   cp .env.example .env.local
#
# For production, set these as Docker Compose environment variables or your
# hosting platform's secrets manager.
# =============================================================================

# -- General ------------------------------------------------------------------

# Set to "development", "staging", or "production"
NODE_ENV=development
APP_MODE=development
# -- Database (PostgreSQL) ----------------------------------------------------

# Connection string for Prisma (see prisma/schema.prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wahabox?schema=public"

# -- Redis (rate limiting) ----------------------------------------------------

REDIS_URL="redis://localhost:6379"

# -- Secrets ------------------------------------------------------------------

# Server master secret for email encryption (min 32 bytes, base64-encoded)
# Generate with: openssl rand -base64 32
SERVER_MASTER_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"

# Session secret for signed cookies
# Generate with: openssl rand -hex 32
SESSION_SECRET="CHANGE_ME_generate_with_openssl_rand_hex_32"

# -- Deployment ---------------------------------------------------------------

# PostgreSQL password (used by docker-compose.yml)
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# Host port for Docker port mapping (default 3000). Set to a different value
# if port 3000 is already taken on your host machine.
HOST_PORT=3000

# -- Amazon SES (email) --------------------------------------------------------

# The verified "from" address for sending emails via SES
SES_FROM_ADDRESS="noreply@wahabox.example.com"

# AWS region for SES (default: us-east-1)
AWS_REGION=us-east-1

# AWS credentials are resolved via the default credential chain (env, ~/.aws/credentials, IAM role, etc.)
# You can set them explicitly if needed:
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME

# Application URL (used in email links)
APP_URL="https://wahabox.localhost/"
